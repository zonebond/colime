# Global fallback for feature-level mock adapters.
# Any feature without an explicit override falls back to this value.
VITE_USE_MOCK_API=true

# Recommended local integration mode:
# - chats/projects use ravens.core
# - toolbox/tasks/library stay on mocks
VITE_USE_MOCK_CHATS=false
VITE_USE_MOCK_PROJECTS=false
VITE_USE_MOCK_TOOLBOX=true
VITE_USE_MOCK_TASKS=true
VITE_USE_MOCK_LIBRARY=true

# Base URL used by real feature services.
# In local development this is expected to go through Vite proxy.
VITE_API_BASE_URL=/core
VITE_RUNTIME_BASE_URL=/runtime

# Mock chat worker remains optional and only applies when chats are mocked.
VITE_USE_MOCK_WORKER=false
